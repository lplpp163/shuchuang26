      "path": "assets/audio/theater_cab8ad0619fe.mp3",
      "text": "Đúng rồi!",
      "bytes": 3661,
      "sha256": "C5DFCF8CDD8CF947B809E9099A667F6A7CC72CB8E197BD49B82FE69AF61B2530"
    },
    {
      "path": "assets/audio/theater_cc3919f570b2.mp3",
      "text": "Ngoan quá, cùng đi thôi!",
      "bytes": 8318,
      "sha256": "44EE1014095E2B4CCB982DA8AF117212D5589CE776A9AE7C484CDE4C1149686E"
    },
    {
      "path": "assets/audio/theater_ccb8f8aa6499.mp3",
      "text": "Cháu nghỉ một chút rồi mình đi nhé. Mình rửa tay rồi ăn cơm nhé?",
      "bytes": 19711,
      "sha256": "F43E2F4818B91D01033610FD846B335E4938A182C58E656BE094F33FCFF04D1A"
    },
    {
      "path": "assets/audio/theater_cf37295e8bea.mp3",
      "text": "Mình mang nước nhé. Cháu thấy gì?",
      "bytes": 10587,
      "sha256": "55B2B89ADF7439123CC71FBE9D5BB8B9F84433F49D8E13CB720E70F47C8838C8"
    },
    {
      "path": "assets/audio/theater_d11bbd9a69bf.mp3",
      "text": "Mình lấy một cái nhé. Cháu cần túi không?",
      "bytes": 13184,
      "sha256": "E4E0A7A1552513D34B409D7095C07D47BB056AC81869A1CF3007882EBE595230"
    },
    {
      "path": "assets/audio/theater_d1500815f6cd.mp3",
      "text": "Bà đẩy nhẹ nhé.",
      "bytes": 6790,
      "sha256": "CF5EF85E5F77718CEF86A5D228E0F50ECD204D10F611D2E3824B42D44ADCE7EE"
    },
    {
      "path": "assets/audio/theater_d3a2299e6ddf.mp3",
      "text": "Cháu thấy nhiều hoa ạ.",
      "bytes": 6730,
      "sha256": "6537ABB5E4DDFD038159A3AA87CCEE170E1F5A0EEA3D51B15D43EDC0156E9736"
    },
    {
      "path": "assets/audio/theater_d568eb38d2e9.mp3",
      "text": "Mình qua đó nhé.",
      "bytes": 6291,
      "sha256": "2781951B6085CE36D2251C412F99FD6C6E3FC3E1B5F4AB166247F5907B00708D"
    },
    {
      "path": "assets/audio/theater_d797cbdc06b4.mp3",
      "text": "Cháu giỏi quá!",
      "bytes": 5639,
      "sha256": "A61FF53FB6621F012FE66CF4386A7FBA40B849A7FA3FB993A16541E2AAAEF2CB"
    },
    {
      "path": "assets/audio/theater_d9b1ae74a7d3.mp3",
      "text": "Còn một cái ạ.",
      "bytes": 4884,
      "sha256": "08F22AD3D39553AE9859BEDF0F50458174517E65F709A135C153A830518AB839"
    },
    {
      "path": "assets/audio/theater_dc35a64fc235.mp3",
      "text": "Bà nhớ cháu quá!",
      "bytes": 6186,
      "sha256": "6BDA0DB25A4057E3D0DAA5488325584F969526FF94521787B6DF1ACA6E8BA621"
    },
    {
      "path": "assets/audio/theater_e701b2caa225.mp3",
      "text": "Cháu thấy con chim ạ.",
      "bytes": 7023,
      "sha256": "D6A96B85E1F48EAEFABC1AEAD8B0C52527BF4528A49DCA2F6DD18943EFA45819"
    },
    {
      "path": "assets/audio/theater_e8ad39dc1423.mp3",
      "text": "Ôi, vào nghỉ một chút nhé.",
      "bytes": 8970,
      "sha256": "025FAE071C682D30D17D37AA868CF447D1E7D492B185BABB4C6CFBAA0FA1BE74"
    },
    {
      "path": "assets/audio/theater_e9533966704d.mp3",
      "text": "Bà chơi cùng cháu.",
      "bytes": 6733,
      "sha256": "E74D643AA4BB612BF247F0C97831C8AD3BA375A47113DE486251B280CD337932"
    },
    {
      "path": "assets/audio/theater_f15b9b60cbd4.mp3",
      "text": "Đẹp quá nhỉ!",
      "bytes": 5304,
      "sha256": "C6C32782D7593F184E9B2F57DCAE83034483B21AAE98DEF76539F44BC0D9F030"
    },
    {
      "path": "assets/audio/theater_f1c0b7b6b29a.mp3",
      "text": "Ở bên kia ạ.",
      "bytes": 5041,
      "sha256": "ED3636879284E8C247932E064096B77F0E214AF448CAFBDE8A246FA405403304"
    },
    {
      "path": "assets/audio/theater_f1f3681e8738.mp3",
      "text": "Cháu dọn khối gỗ ạ.",
      "bytes": 7071,
      "sha256": "015803816EE3B0B32B594DC8E367D96B845E0B7EA5283F214BE1338085385A74"
    },
    {
      "path": "assets/audio/theater_f20c1ea9caef.mp3",
      "text": "Cháu làm xong rồi ạ.",
      "bytes": 6914,
      "sha256": "C62141CE5575520E877272E039F7EDD6A39A97B977F63B1641AA3F25B4746178"
    },
    {
      "path": "assets/audio/theater_f40436327ec0.mp3",
      "text": "Mai kể bà nghe về bạn mới nhé. Mình rửa tay rồi ăn cơm nhé?",
      "bytes": 20341,
      "sha256": "206157E933F6E4B9DD40ED82C4572A2187039823322B35BD56A6670CFF1687AA"
    },
    {
      "path": "assets/audio/theater_f71b40293d05.mp3",
      "text": "Cháu cầm túi rác ạ.",
      "bytes": 7329,
      "sha256": "E09758C82A50E91D22E6209057F3359272714545FA33BD5803D86BF5BC99345B"
    }
  ]
}
